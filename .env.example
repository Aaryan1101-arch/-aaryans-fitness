# Copy this file to .env.local for local dev, or set these in Vercel
# Project Settings → Environment Variables for production.

# ── Supabase (content + admin auth) ──────────────────────────────────────────
# Required. Without these, the public site falls back to bundled defaults
# and the admin panel cannot sign in.
#   1. Create a project at https://supabase.com
#   2. Settings → API → copy "Project URL" and "anon public" key
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_key_here

# ── EmailJS (contact form) ───────────────────────────────────────────────────
# Sign up free at https://www.emailjs.com/ then:
#   1. Add an Email Service (Gmail, Outlook, etc.)  → copy Service ID
#   2. Create a template — use these variables in the body:
#        {{user_name}}  {{user_email}}  {{user_number}}  {{message}}
#      → copy Template ID
#   3. Account → General → Public Key → copy it
#
# Without these vars the contact section shows direct phone/email links instead.
REACT_APP_EMAILJS_SERVICE_ID=your_service_id
REACT_APP_EMAILJS_TEMPLATE_ID=your_template_id
REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key

# ── Sanity (LEGACY — not used by the live site) ──────────────────────────────
# The repo has Sanity client code from an earlier iteration but the public
# site reads from Supabase. Leave these unset; the Sanity client logs a
# harmless warning if missing.
# REACT_APP_SANITY_PROJECT_ID=your_project_id_here
# REACT_APP_SANITY_DATASET=production
